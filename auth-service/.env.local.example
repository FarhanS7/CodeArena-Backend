# JWT Secret for authentication (use a random 32+ character string)
JWT_SECRET=your-super-secure-jwt-secret-change-this-32-chars-min

# Token expiration times
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Database (used by Docker Compose)
DB_HOST=localhost
DB_PORT=21000
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=auth_db

# Environment
NODE_ENV=development
PORT=3100